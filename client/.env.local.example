NEXT_PUBLIC_API_URL=http://localhost:8010
CAPACITOR_DEV_URL=http://localhost:3010
NEXT_PUBLIC_SHARE_DEBUG=false
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Native Sign-In (Capacitor build time)
# iOS OAuth Client ID 的 Web 版本，用於 serverClientId
# 取得：Google Cloud Console → APIs & Services → Credentials → Web application OAuth Client
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# Puppeteer screenshot service URL
# 本地開發: http://localhost:4000
# Production: https://<render-service>.onrender.com
NEXT_PUBLIC_PUPPETEER_SERVICE_URL=http://localhost:4000
